PORT=8000
ENVIRONMENT=development
TESTING=false

# Firebase Admin SDK
# Local dev: point to your JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# Production: paste the full JSON contents as a single-line string (takes priority over PATH)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Frontend URL for CORS (set to your Vercel deployment URL in production)
FRONTEND_URL=

# MongoDB
MONGODB_URI=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# LLM, Audio & Proxy
GEMINI_API_KEY=
LAVA_SECRET_KEY=
